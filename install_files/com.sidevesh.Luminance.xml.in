<node>
  <interface name="@APP_INFO_PACKAGE_NAME@">
    <!-- Signal to notify listeners (e.g. Gnome Extension) to show OSD -->
    <signal name="ShowOSD">
      <arg type="d" name="brightness_percentage"/>
      <arg type="s" name="monitor_name"/>
    </signal>

    <!-- Signal to notify listeners to show contrast OSD -->
    <signal name="ShowContrastOSD">
      <arg type="d" name="contrast_percentage"/>
      <arg type="s" name="monitor_name"/>
    </signal>

    <method name="GetMonitors">
      <!-- Returning JSON string for flexibility given C structure -->
      <arg type="s" name="monitors_json" direction="out"/>
    </method>

    <method name="SetBrightness">
      <arg type="s" name="monitor_id" direction="in"/>
      <arg type="d" name="value" direction="in"/>
    </method>

    <!-- Same as SetBrightness but does not emit ShowOSD (used by UI surfaces, e.g. GNOME Quick Settings, that already show their own visual feedback) -->
    <method name="SetBrightnessQuiet">
      <arg type="s" name="monitor_id" direction="in"/>
      <arg type="d" name="value" direction="in"/>
    </method>

    <method name="SetContrast">
      <arg type="s" name="monitor_id" direction="in"/>
      <arg type="d" name="value" direction="in"/>
    </method>

    <method name="Quit">
    </method>
  </interface>
</node>
